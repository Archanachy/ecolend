# EcoLend environment. Copy to `.env` and fill real values.
# `.env` is git-ignored and must NEVER be committed. This file ships
# placeholders only.

# --- Database ---
MONGODB_URI=mongodb://mongo:27017/ecolend

# --- Sessions ---
SESSION_SECRET=replace-with-a-long-random-string

# --- Field-level encryption (AES-256-GCM) ---
# 256-bit key, hex-encoded (64 hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENC_KEY=replace-with-64-hex-chars

# --- Khalti (sandbox) ---
# KHALTI_ENV selects the base URL (sandbox -> dev.khalti.com). Never hardcode the URL.
# In dev, KHALTI_SECRET_KEY is the live_secret_key from test-admin.khalti.com
# (valid only against the dev.khalti.com sandbox).
KHALTI_ENV=sandbox
KHALTI_SECRET_KEY=replace-with-sandbox-secret-key

# --- Brute-force / admin allow-list ---
ADMIN_IP_ALLOWLIST=

# --- CAPTCHA (hCaptcha or reCAPTCHA v2) ---
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# --- Mail transport (email verification / password reset) ---
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@ecolend.local
